export ZSH="{{ .chezmoi.homeDir }}/.oh-my-zsh"
export PATH="{{ .chezmoi.homeDir }}/.local/bin:$PATH"

ZSH_THEME="jaintp"

plugins=(git)

source $ZSH/oh-my-zsh.sh

# User configuration
export TERM=xterm-256color
export GTK_THEME="catppuccin-mocha-mauve-standard+default"

# Aliases
alias btw="fastfetch"
alias ..="cd .."
alias ls="lsd"
alias cursor='env XDG_DATA_DIRS=/usr/share:/usr/local/share cursor'
{{- if eq .chezmoi.hostname "galdheim" }}
alias rpi='ssh 192.168.0.189'
{{- end }}
eval $(thefuck --alias)


fpath+=~/.zfunc; autoload -Uz compinit; compinit

zstyle ':completion:*' menu select

if [ -d "$HOME/.swiftenv" ]; then
    export SWIFTENV_ROOT="$HOME/.swiftenv"
    export PATH="$SWIFTENV_ROOT/bin:$PATH"
    eval "$(swiftenv init -)"
fi

eval "$(zoxide init --cmd cd zsh)" 

# in ~/.bashrc or ~/.zshrc
if ! pgrep -u "$USER" ssh-agent >/dev/null; then
  eval "$(ssh-agent -s)"
fi

if [ -f ~/.ssh/id_ed25519 ]; then
    ssh-add -l >/dev/null 2>&1 || ssh-add ~/.ssh/id_ed25519
fi
