#!/usr/bin/env bash
set -eo pipefail

CACHE_DIR="$HOME/.cache/playerctl"
mkdir -p "$CACHE_DIR"

if [[ $# -eq 0 ]]; then
    echo "Usage: $(basename "$0") {art|title|length|status|client|album|artist}" >&2
    exit 1
fi

fetch_album_art() {
    local url
    url=$(playerctl metadata mpris:artUrl 2>/dev/null || true)

    if [[ -z "$url" ]]; then
        echo "None"
        return
    fi

    if [[ "$url" == file://* ]]; then
        local filepath="${url#file://}"
        if [[ -f "$filepath" ]]; then
            echo "$filepath"
        else
            echo "Local file not found: $filepath" >&2
            echo "None"
        fi
        return
    fi

    # Remote URLs
    local mime_type
    mime_type=$(curl -sI "$url" | rg -i "Content-Type" | awk '{print $2}' | tr -d '\r' || true)

    local extension="unknown"
    case "$mime_type" in
        image/jpeg) extension="jpg" ;;
        image/png)  extension="png" ;;
        image/gif)  extension="gif" ;;
        image/webp) extension="webp" ;;
    esac

    if [[ "$extension" == "unknown" ]]; then
        echo "Unsupported image type: $mime_type" >&2
        echo "None"
        return
    fi

    local filename
    filename=$(basename "$url" | cut -d'?' -f1)
    local filepath="$CACHE_DIR/$filename.$extension"

    # Only download if we don't have it cached
    if [[ ! -f "$filepath" ]]; then
        curl -s "$url" -o "$filepath" || true
    fi
    echo "$filepath"
}

get_title() {
    playerctl metadata --format "{{ xesam:title }}" 2>/dev/null | cut -c1-25 || true
}

convert_length() {
    local length
    length=$(playerctl metadata --format "{{ mpris:length }}" 2>/dev/null || true)

    if [[ -z "$length" || ! "$length" =~ ^[0-9]+$ ]]; then
        echo ""
        return
    fi

    local seconds=$((length / 1000000))
    local hours=$((seconds / 3600))
    local minutes=$(( (seconds % 3600) / 60 ))
    local secs=$((seconds % 60))
    
    if (( hours > 0 )); then
        printf "%02d:%02d:%02d\n" "$hours" "$minutes" "$secs"
    else
        printf "%02d:%02d\n" "$minutes" "$secs"
    fi
}

get_status() {
    playerctl status 2>/dev/null || true
}

get_client() {
    local client
    # Guard: Use rg instead of grep
    client=$(playerctl metadata --format "{{ mpris:trackid }}" 2>/dev/null | rg -io "chromium|zen-beta|firefox|spotify" || true)

    if [[ -z "$client" ]]; then
        echo ""
        return
    fi
    
    # ensure consistent casing
    client=$(echo "$client" | tr '[:upper:]' '[:lower:]')

    case "$client" in
        zen-beta|firefox)
            local site_name
            site_name=$(playerctl metadata --format "{{ xesam:url }}" 2>/dev/null | awk -F/ '{print $3}' | sed 's/^www\.//' || true)
            if [[ -n "$site_name" ]]; then
                echo "Zen Browser - $site_name"
            else
                echo "Zen Browser"
            fi
            ;;
        spotify)
            echo "Spotify"
            ;;
        chromium)
            echo "Chromium"
            ;;
        *)
            echo ""
            ;;
    esac
}

get_album() {
    playerctl metadata --format "{{ xesam:album }}" 2>/dev/null || true
}

get_artist() {
    playerctl metadata --format "{{ xesam:artist }}" 2>/dev/null | cut -c1-30 || true
}

case "$1" in
    art) fetch_album_art ;;
    title) get_title ;;
    length) convert_length ;;
    status) get_status ;;
    client) get_client ;;
    album) get_album ;;
    artist) get_artist ;;
    *) 
        echo "Usage: $(basename "$0") {art|title|length|status|client|album|artist}" >&2
        exit 1
        ;;
esac
