{{- $primary_monitor := "DP-5" -}}
{{- $secondary_monitor := "HDMI-A-5" -}}
{{- if eq .chezmoi.hostname "ArchBox" -}}
  {{- $primary_monitor = "eDP-1" -}}
  {{- $secondary_monitor = "" -}}
{{- end -}}
$hypr = ~/.config/hypr
source = $HOME/.config/hypr/mocha.conf

$accent = $mauve
$accentAlpha = $mauveAlpha
$font = JetBrainsMono Nerd Font

# GENERAL
general {
    hide_cursor = true
    ignore_empty_input = true
    text_trim = true
}

#BACKGROUND
background {
    monitor = {{ $primary_monitor }}
    path = ~/.config/background
#    path = screenshot
    blur_passes = 2
    contrast = 0.8916
    brightness = 0.7172
    vibrancy = 0.1696
    vibrancy_darkness = 0
}

{{- if $secondary_monitor }}
#BACKGROUND
background {
    monitor = {{ $secondary_monitor }}
    path = ~/.config/background
#    path = screenshot
    blur_passes = 4
    contrast = 0.8916
    brightness = 0.7172
    vibrancy = 0.1696
    vibrancy_darkness = 0
}
{{- end }}

# Location
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(bash ~/.local/bin/weatherfetch location)"
    color = rgba(207, 207, 207, 1)
    font_size = 14
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 0, 350px
    halign = center
    valign = center
}

# Weather
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(bash ~/.local/bin/weatherfetch weather)"
    color = rgba(255, 255, 255, 1)
    font_size = 14
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 0, 330px
    halign = center
    valign = center
}

# Hours
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(date +"%H")"
    color = rgba(207, 207, 207, 1)
    shadow_size = 3
    shadow_color = rgb(0,0,0)
    shadow_boost = 1.2
    font_size = 150
    font_family = AlfaSlabOne 
    position = 0, 160
    halign = center
    valign = center
}

# Minutes
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(date +"%M")"
    color = rgba(255, 255, 255, 1)
    shadow_size = 3
    shadow_color = rgb(0,0,0)
    shadow_boost = 1.2
    font_size = 150
    font_family = AlfaSlabOne 
    position = 0, 0
    halign = center
    valign = center
}

# Seconds
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "<b>$(date +"%S")</b>"
    color = rgba(125, 125, 125, 1)
    shadow_size = 3
    shadow_color = rgb(0,0,0)
    shadow_boost = 1.2
    font_size = 25
    font_family = AlfaSlabOne 
    position = 75, -65
    halign = center
    valign = center
}

# Day
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo -e "$(date +"%A")"
    color = rgba(207, 207, 207, 1)
    font_size = 14
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 0, -85
    halign = center
    valign = center
}

# Date
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo -e "$(date +"%d %B %Y")"
    color = rgba(255, 255, 255, 1)
    font_size = 14
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 0, -110
    halign = center
    valign = center
}

# INPUT FIELD
input-field {
    monitor = {{ $primary_monitor }}
    size = 300, 60
    outline_thickness = 1
    dots_size = 0.1
    dots_spacing = 0.5
    dots_center = true
    outer_color = rgba(255, 255, 255, 1)
    inner_color = rgba(125, 125, 125, 0.1)
    font_color = rgba(255, 255, 255, 1)
    check_color = rgba(207, 207, 207, 1)
    fail_color = rgba(161, 161, 161, 1)
    fail_text = <i>$FAIL <b>($ATTEMPTS)</b></i>
    fade_on_empty = false
    font_family = JetBrains Mono Nerd Font Mono
    placeholder_text = $USER
    hide_input = false
    position = 0, -180
    halign = center
    valign = center
    zindex = 10
}

# Album Art
image {
    monitor = {{ $primary_monitor }}
    path = 
    size = 100
    rounding = 5
    border_size = 0
    rotate = 0 # degrees, counter-clockwise
    reload_time = 2
    reload_cmd = ~/.local/bin/playerctl-helper art
    position = -50.2%, 20
    halign = right
    valign = bottom
}

# Media Client
label {
    monitor = {{ $primary_monitor }}
    text= cmd[update:1000] echo "$(~/.local/bin/playerctl-helper client)"
    color = rgba(255, 255, 255, 0.6)
    font_size = 10
    font_family = JetBrains Mono Nerd Font Mono 
    position = 0, 120
    halign = center
    valign = bottom
}

# Song Title
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(~/.local/bin/playerctl-helper title)"
    color = rgba(255, 255, 255, 0.8)
    font_size = 12
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 50.2%, 100
    halign = left
    valign = bottom
}

# Artist
label {
    monitor = {{ $primary_monitor }}
    text = cmd[update:1000] echo "$(~/.local/bin/playerctl-helper artist)"
    text_align = left
    color = rgba(255, 255, 255, 0.8)
    font_size = 10
    font_family = JetBrains Mono Nerd Font Mono ExtraBold
    position = 50.2%, 80
    halign = left
    valign = bottom
}

# Album
label {
    monitor = {{ $primary_monitor }}
    text= cmd[update:1000] echo "$(~/.local/bin/playerctl-helper album)"
    color = rgba(255, 255, 255, 1)
    font_size = 10 
    font_family = JetBrains Mono Nerd Font Mono
    position = 50.2%, 60
    halign = left
    valign = bottom
}

# Song Duration
label {
    monitor = {{ $primary_monitor }}
    text= cmd[update:1000] echo "$(~/.local/bin/playerctl-helper length)"
    color = rgba(255, 255, 255, 1)
    font_size = 11
    font_family = JetBrains Mono Nerd Font Mono 
    position = 50.2%, 40
    halign = left
    valign = bottom
}

# Playing Status
label {
    monitor = {{ $primary_monitor }}
    text= cmd[update:1000] echo "$(~/.local/bin/playerctl-helper status)"
    color = rgba(255, 255, 255, 1)
    font_size = 14
    font_family = JetBrains Mono Nerd Font Mono 
    position = 50.2%, 20
    halign = left
    valign = bottom
}
